    "Classic spaghetti carbonara and warm beef stew for a comforting end to the day." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Classic spaghetti carbonara and warm beef stew for a comforting end to the day."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clásico espagueti carbonara y guiso de carne para un final reconfortante del día"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spaghetti carbonara classique et ragoût de bœuf chaud pour une fin de journée réconfortante."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "クラシックなスパゲッティ・カルボナーラと温かいビーフシチューで、一日の終わりを心地よく締めくくりましょう。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "经典的意大利面碳烤和温暖的牛肉炖菜，为一天画上圆满的句号。"
          }
        }
      }
    },
