    "Spaghetti Carbonara for 2 people.\nIngredients: Spaghetti 200g, Eggs 2, Pancetta 100g.\nCook spaghetti. Fry pancetta. Mix eggs and cheese. Combine all." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spaghetti Carbonara for 2 people.\nIngredients: Spaghetti 200g, Eggs 2, Pancetta 100g.\nCook spaghetti. Fry pancetta. Mix eggs and cheese. Combine all."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Espagueti a la carbonara para 2 personas.\nIngredientes: Espagueti 200g, Huevos 2, Panceta 100g.\nCuece la pasta. Fríe la panceta. Mezcla los huevos y el queso. Combina todo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spaghetti carbonara pour 2 personnes.\nIngrédients : Spaghetti 200g, Œufs 2, Pancetta 100g.\nFaites cuire les pâtes. Faites revenir la pancetta. Mélangez les œufs et le fromage. Assemblez le tout."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2人分のスパゲッティ・カルボナーラ。\n材料: スパゲッティ 200g、卵 2個、パンチェッタ 100g。\nパスタをゆでる。パンチェッタを炒める。卵とチーズを混ぜる。すべてを合わせる。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2人份培根蛋面。\n食材：意大利面 200g、鸡蛋 2个、意式培根 100g。\n煮意大利面。煎意式培根。混合鸡蛋和奶酪。把所有材料拌匀。"
          }
        }
      }
    },
