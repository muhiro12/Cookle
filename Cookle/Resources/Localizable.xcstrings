    "recipe.shareLink.footer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Save this link in reminders, calendar events, or notes so you can reopen this recipe in Cookle later. It does not share the recipe details with someone else."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guarda este enlace en recordatorios, eventos del calendario o notas para volver a abrir esta receta en Cookle más tarde. No comparte los detalles de la receta con otra persona."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistrez ce lien dans des rappels, des événements de calendrier ou des notes afin de pouvoir rouvrir cette recette dans Cookle plus tard. Il ne partage pas les détails de la recette avec une autre personne."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このリンクをリマインダー、カレンダー予定、メモなどに保存しておくと、後でこのレシピを Cookle で開き直せます。ほかの人にレシピ内容を共有するものではありません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将此链接保存到提醒事项、日历事件或备忘录中，以便稍后在 Cookle 中重新打开这道食谱。它不会把食谱详情分享给其他人。"
          }
        }
      }
    },
    "recipe.shareLink.message" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Save this link in reminders, calendar events, or notes to reopen %@ in Cookle later."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guarda este enlace en recordatorios, eventos del calendario o notas para volver a abrir %@ en Cookle más tarde."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistrez ce lien dans des rappels, des événements de calendrier ou des notes pour rouvrir %@ dans Cookle plus tard."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このリンクをリマインダー、カレンダー予定、メモなどに保存しておくと、後で Cookle で %@ を開き直せます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
