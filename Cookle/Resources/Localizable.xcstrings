        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa queso parmesano recién rallado para obtener el mejor sabor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez du parmesan fraîchement râpé pour un goût optimal."
